# Copie este arquivo para .env.local e preencha os valores
# Encontre em: Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_publishable_key_aqui

# Usada apenas no servidor (admin) — nunca exposta ao navegador
SUPABASE_SERVICE_KEY=sua_secret_key_aqui

# Senha para o painel admin — use uma senha forte e única
ADMIN_PASSWORD=troque_por_uma_senha_forte

# Chave da API Anthropic — usada pelo agente de pesquisa (research-agent.js)
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sua_anthropic_api_key_aqui
